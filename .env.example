DISCORD_BOT_TOKEN=
GUILD_ID=
WELCOME_CHANNEL_ID=
ACCESS_REQUEST_CHANNEL_ID=
GUEST_ROLE_ID=
HIGHEST_ROLE_ID=
LOWEST_ROLE_ID=
VERIFIED_ROLE_ID=
LANG=en-US

# --- Spam-bot detection ---
# Master switches. Roll out with SPAM_DRY_RUN=true (logs what it WOULD do, no
# real timeouts/deletes) until thresholds are tuned, then set it to false.
SPAM_DETECTION_ENABLED=true
SPAM_DRY_RUN=true

# Where detections are logged, and who gets pinged.
SPAM_LOG_CHANNEL_ID=732076147466174474
OWNER_USER_ID=196685652249673728

# Honeypot channels (comma-separated).
#   HONEYPOT_CHANNEL_IDS           = never legitimately used (each hit is strong)
#   SECONDARY_HONEYPOT_CHANNEL_IDS = occasional legit use; only counts when BOTH hit
#   HONEYPOT_VOICE_CHANNEL_IDS     = the subset that are voice-channel text chats (extra weight)
HONEYPOT_CHANNEL_IDS=759119673912066108,751226562027847681,747297486749827122
SECONDARY_HONEYPOT_CHANNEL_IDS=761481617000235018,733354393096945736
HONEYPOT_VOICE_CHANNEL_IDS=751226562027847681,747297486749827122,761481617000235018,733354393096945736

# Roles.
#   EXCLUDED_ROLE_ID  = hand-verified; warn-only, never muted/deleted
#   DEFUNCT_ROLE_*    = defunct roles; gaining BOTH is a plant signal
EXCLUDED_ROLE_ID=733450371242131517
DEFUNCT_ROLE_A_ID=740609347519774744
DEFUNCT_ROLE_B_ID=732628048503111705
DEFUNCT_ROLE_SIGNAL_ENABLED=true

# Thresholds & tuning (optional; defaults shown).
SPAM_IDENTITY_WARN_THRESHOLD=6
SPAM_MUTE_THRESHOLD=12
SPAM_MAX_TIMEOUT_MS=2419200000
SPAM_WARN_DELAY_MS=15000
SPAM_ACTION_COOLDOWN_MS=300000
SPAM_WINDOW_MAX_MS=900000
SPAM_PER_USER_EVENT_CAP=200
